<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="LangCode">en</sys:String>

    <!-- Workflow bar -->
    <sys:String x:Key="Step1">Paste URL</sys:String>
    <sys:String x:Key="Step2">Load Metadata</sys:String>
    <sys:String x:Key="Step3">Choose Action &amp; Start</sys:String>

    <!-- Sections -->
    <sys:String x:Key="SectionPlatform">PLATFORM</sys:String>
    <sys:String x:Key="SectionQuickActions">QUICK ACTIONS</sys:String>
    <sys:String x:Key="SectionAction">ACTION</sys:String>
    <sys:String x:Key="SectionYTSettings">YOUTUBE SETTINGS</sys:String>
    <sys:String x:Key="SectionDLSettings">DOWNLOAD SETTINGS</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="TipPaste">Paste from Clipboard</sys:String>
    <sys:String x:Key="BtnFetch">Metadata</sys:String>
    <sys:String x:Key="BtnCopyTitle">📋 Copy Title</sys:String>
    <sys:String x:Key="BtnCopyUrl">🔗 Copy URL</sys:String>
    <sys:String x:Key="BtnOpenBrowser">🌐 Open in Browser</sys:String>
    <sys:String x:Key="TipCopyTitle">Copy title to clipboard</sys:String>
    <sys:String x:Key="TipCopyUrl">Copy source URL to clipboard</sys:String>
    <sys:String x:Key="TipOpenBrowser">Open video in default browser</sys:String>
    <sys:String x:Key="BtnBrowse">📂 Browse</sys:String>
    <sys:String x:Key="BtnStart">Start</sys:String>

    <!-- Mode cards -->
    <sys:String x:Key="ModeUploadTitle">YouTube Upload</sys:String>
    <sys:String x:Key="ModeUploadDesc">Upload Reel directly as a Short</sys:String>
    <sys:String x:Key="ModeDownloadTitle">Download</sys:String>
    <sys:String x:Key="ModeDownloadDesc">Save MP4 locally</sys:String>

    <!-- YouTube settings -->
    <sys:String x:Key="LblTitleField">Title</sys:String>
    <sys:String x:Key="LblDescField">Description</sys:String>
    <sys:String x:Key="TipEditDesc">Edit Description</sys:String>
    <sys:String x:Key="TipDescBox">Click ✏ or double-click to edit</sys:String>
    <sys:String x:Key="LblVisibility">Visibility</sys:String>
    <sys:String x:Key="PrivacyPublic">Public</sys:String>
    <sys:String x:Key="PrivacyUnlisted">Unlisted</sys:String>
    <sys:String x:Key="PrivacyPrivate">Private</sys:String>
    <sys:String x:Key="FpMetadata">Metadata only</sys:String>
    <sys:String x:Key="FpLight">Light</sys:String>
    <sys:String x:Key="FpStandard">Standard</sys:String>
    <sys:String x:Key="FpStrong">Strong</sys:String>

    <!-- Download settings -->
    <sys:String x:Key="LblSavePath">Save Path</sys:String>

    <!-- Status / code-behind -->
    <sys:String x:Key="StatusStarting">Starting backend…</sys:String>
    <sys:String x:Key="StatusBackendReady">Backend ready</sys:String>
    <sys:String x:Key="StatusBackendDown">Backend not reachable</sys:String>
    <sys:String x:Key="StatusBackendErrPrefix">Backend error:</sys:String>
    <sys:String x:Key="StatusLoading">Loading metadata…</sys:String>
    <sys:String x:Key="StatusMetaLoaded">Metadata loaded</sys:String>
    <sys:String x:Key="StatusLoadErr">Error loading metadata</sys:String>
    <sys:String x:Key="StatusCompleted">Completed successfully!</sys:String>
    <sys:String x:Key="StatusCancelled">Cancelled</sys:String>
    <sys:String x:Key="StatusErrPrefix">Error:</sys:String>
    <sys:String x:Key="ErrNoUrl">Please enter a URL.</sys:String>
    <sys:String x:Key="ErrNoBackend">Backend not ready.</sys:String>
    <sys:String x:Key="ErrNoTitle">Please enter a title.</sys:String>
    <sys:String x:Key="ErrNoSavePath">Please choose a save location.</sys:String>
    <sys:String x:Key="ErrNoMeta">No metadata received.</sys:String>
    <sys:String x:Key="ErrPrefix">Error:</sys:String>

    <!-- Settings window -->
    <sys:String x:Key="SettingsTitle">Settings</sys:String>
    <sys:String x:Key="TipSettings">Open Settings</sys:String>
    <sys:String x:Key="SettingsGeneral">GENERAL</sys:String>
    <sys:String x:Key="SettingsLanguage">Language</sys:String>
    <sys:String x:Key="SettingsAutoPaste">Auto-paste URL from clipboard on focus</sys:String>
    <sys:String x:Key="SettingsUpload">UPLOAD DEFAULTS</sys:String>
    <sys:String x:Key="SettingsDefaultPrivacy">Default visibility</sys:String>
    <sys:String x:Key="SettingsAutoShorts">Automatically add "#Shorts" to description</sys:String>
    <sys:String x:Key="SettingsFpBypass">Enable fingerprint bypass</sys:String>
    <sys:String x:Key="SettingsDownload">DOWNLOAD DEFAULTS</sys:String>
    <sys:String x:Key="SettingsDefaultOutputDir">Default save location</sys:String>
    <sys:String x:Key="SettingsBackend">BACKEND</sys:String>
    <sys:String x:Key="SettingsBackendUrl">Backend URL</sys:String>
    <sys:String x:Key="SettingsBackendTimeout">Startup timeout (seconds)</sys:String>
    <sys:String x:Key="BtnSaveSettings">Save</sys:String>
    <sys:String x:Key="BtnCancelSettings">Cancel</sys:String>

    <!-- Additional quick actions -->
    <sys:String x:Key="BtnCopyDesc">Copy Description</sys:String>
    <sys:String x:Key="BtnCopyTags">Copy Tags</sys:String>
    <sys:String x:Key="BtnClearForm">Reset Form</sys:String>
    <sys:String x:Key="TipCopyDesc">Copy description to clipboard</sys:String>
    <sys:String x:Key="TipCopyTags">Copy tags as plain text</sys:String>
    <sys:String x:Key="TipClearForm">Clear input and metadata</sys:String>

</ResourceDictionary>
