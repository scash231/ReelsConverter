<Window x:Class="ReelsConverterUI.DevConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dev Console" Width="520" Height="320"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Icon="app.ico">

    <Border x:Name="RootBorder" CornerRadius="16"
            Background="#0A0A0C"
            BorderBrush="{StaticResource BorderSub}" BorderThickness="1"
            Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="WinScale"/>
                <TranslateTransform x:Name="WinTranslate"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#111113" CornerRadius="16,16,0,0"
                    Padding="10,0" MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⌘" FontSize="10" Foreground="{StaticResource Accent}"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource DevConsoleTitle}" FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSec}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnConsoleHelp"
                                Style="{StaticResource IconBtn}"
                                Width="22" Height="22" Margin="0,0,2,0"
                                Click="Help_Click"
                                ToolTip="{DynamicResource DevConsoleHelpTip}">
                            <TextBlock Text="?" FontSize="9" FontWeight="Bold"/>
                        </Button>
                        <Button Style="{StaticResource IconBtn}"
                                Width="22" Height="22" Margin="0,0,2,0"
                                Click="Reattach_Click"
                                ToolTip="{DynamicResource DevConsoleReattach}">
                            <TextBlock Text="📌" FontSize="9"/>
                        </Button>
                        <Button Style="{StaticResource IconBtn}"
                                Width="22" Height="22" Margin="0,0,2,0"
                                Click="Clear_Click"
                                ToolTip="{DynamicResource DevConsoleClear}">
                            <TextBlock Text="🗑" FontSize="9"/>
                        </Button>
                        <Button Style="{StaticResource IconBtn}"
                                Width="22" Height="22" Margin="0,0,2,0"
                                Click="Minimize_Click"
                                ToolTip="{DynamicResource DevConsoleMinimize}">
                            <TextBlock Text="─" FontSize="9"/>
                        </Button>
                        <Button Style="{StaticResource IconBtn}"
                                Foreground="{StaticResource ErrorRed}"
                                Width="22" Height="22"
                                Click="Close_Click">
                            <TextBlock Text="✕" FontSize="9"/>
                        </Button>
                    </StackPanel>
                    <Popup x:Name="ConsoleHelpPopup"
                           Placement="Bottom"
                           VerticalOffset="4"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{StaticResource BgElevated}"
                                BorderBrush="{StaticResource BorderSub}"
                                BorderThickness="1" CornerRadius="12"
                                Padding="14,12" MinWidth="220">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource DevConsoleHelpTitle}" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="Consolas" FontSize="10"
                                           Foreground="{StaticResource Accent}" Text="help"
                                           Margin="0,0,0,2"/>
                                <TextBlock FontSize="10" Foreground="{StaticResource TextPrimary}"
                                           Text="{DynamicResource CmdHelpDesc}" Margin="0,0,0,6"/>
                                <TextBlock FontFamily="Consolas" FontSize="10"
                                           Foreground="{StaticResource Accent}" Text="clear / cls"
                                           Margin="0,0,0,2"/>
                                <TextBlock FontSize="10" Foreground="{StaticResource TextPrimary}"
                                           Text="{DynamicResource CmdClearDesc}" Margin="0,0,0,6"/>
                                <TextBlock FontFamily="Consolas" FontSize="10"
                                           Foreground="{StaticResource Accent}" Text="status"
                                           Margin="0,0,0,2"/>
                                <TextBlock FontSize="10" Foreground="{StaticResource TextPrimary}"
                                           Text="{DynamicResource CmdStatusDesc}" Margin="0,0,0,6"/>
                                <TextBlock FontFamily="Consolas" FontSize="10"
                                           Foreground="{StaticResource Accent}" Text="info"
                                           Margin="0,0,0,2"/>
                                <TextBlock FontSize="10" Foreground="{StaticResource TextPrimary}"
                                           Text="{DynamicResource CmdInfoDesc}" Margin="0,0,0,6"/>
                                <Border Height="1" Background="{StaticResource BorderSub}" Margin="0,2,0,6"/>
                                <TextBlock FontSize="10" Foreground="{StaticResource TextSec}"
                                           Text="{DynamicResource CmdFallbackDesc}"
                                           TextWrapping="Wrap" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Border>

            <!-- Console output -->
            <TextBox x:Name="TxtConsole" Grid.Row="1"
                     Background="#0A0A0C" BorderThickness="0"
                     Foreground="#5A8A5A" FontFamily="Consolas" FontSize="10"
                     IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" Padding="10,6"/>

            <!-- Command input -->
            <Border Grid.Row="2" Background="#111113" BorderBrush="{StaticResource BorderSub}"
                    BorderThickness="0,1,0,0" Padding="6,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="›" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource Accent}"
                               VerticalAlignment="Center" Margin="4,0,6,0"/>
                    <TextBox x:Name="TxtInput" Grid.Column="1"
                             Background="#0A0A0C" BorderThickness="0"
                             Foreground="#C0C0C0" FontFamily="Consolas" FontSize="10"
                             CaretBrush="#C0C0C0" Padding="4,3"
                             KeyDown="TxtInput_KeyDown"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
