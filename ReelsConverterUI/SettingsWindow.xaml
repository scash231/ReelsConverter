<Window x:Class="ReelsConverterUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="520" Height="580"
        Icon="app.ico"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border x:Name="RootBorder" CornerRadius="16"
            Background="{StaticResource BgDeep}"
            BorderBrush="{StaticResource BorderSub}" BorderThickness="1"
            Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="WindowScale"/>
                <TranslateTransform x:Name="WindowTranslate"/>
            </TransformGroup>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ Title Bar ═══ -->
            <Border Grid.Row="0" Background="#141416" CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="⚙" FontSize="13" Margin="0,0,8,0"
                                   Foreground="{StaticResource TextSec}" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource SettingsTitle}" FontWeight="SemiBold"
                                   FontSize="13" Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource IconBtn}"
                            Foreground="{StaticResource ErrorRed}"
                            Width="30" Height="30" Margin="0,0,4,0"
                            Click="Cancel_Click">
                        <TextBlock Text="✕" FontSize="11"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ Tab Bar ═══ -->
            <Border Grid.Row="1" Background="#18181A"
                    BorderBrush="#2A2A2F" BorderThickness="0,0,0,1"
                    Padding="10,6,10,6">
                <StackPanel x:Name="TabBar" Orientation="Horizontal">
                    <RadioButton x:Name="TabGeneral" Style="{StaticResource TabBtn}"
                                 Content="{DynamicResource SettingsTabGeneral}" IsChecked="True"
                                 GroupName="SettingsTab" Checked="Tab_Changed"/>
                    <RadioButton x:Name="TabUpload" Style="{StaticResource TabBtn}"
                                 Content="{DynamicResource SettingsTabUpload}"
                                 GroupName="SettingsTab" Checked="Tab_Changed"/>
                    <RadioButton x:Name="TabDownload" Style="{StaticResource TabBtn}"
                                 Content="{DynamicResource SettingsTabDownload}"
                                 GroupName="SettingsTab" Checked="Tab_Changed"/>
                    <RadioButton x:Name="TabAdvanced" Style="{StaticResource TabBtn}"
                                 Content="{DynamicResource SettingsTabAdvanced}"
                                 GroupName="SettingsTab" Checked="Tab_Changed"/>
                </StackPanel>
            </Border>

            <!-- ═══ Content ═══ -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Margin="0">
                <Grid Margin="14,10,14,6">

                    <!-- ── General Tab ── -->
                    <StackPanel x:Name="PanelGeneral">
                        <Border Background="#992A2A2E" BorderBrush="#50505A" BorderThickness="1"
                                CornerRadius="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsAppearance}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}"
                                           Margin="14,10,14,2"/>
                                <Border Padding="14,9" BorderBrush="#2E2E36" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsLanguage}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <Border HorizontalAlignment="Right"
                                                BorderBrush="#50505A" BorderThickness="1" CornerRadius="8">
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="SLangDE" Content="DE"
                                                        Style="{StaticResource IconBtn}"
                                                        FontSize="10" FontWeight="SemiBold"
                                                        Width="30" Height="24"
                                                        Click="SLangDE_Click"/>
                                                <Border Width="1" Background="#50505A" Margin="0,5"/>
                                                <Button x:Name="SLangEN" Content="EN"
                                                        Style="{StaticResource IconBtn}"
                                                        FontSize="10" FontWeight="SemiBold"
                                                        Width="30" Height="24"
                                                        Click="SLangEN_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border Padding="14,9">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsAlwaysOnTop}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox x:Name="ChkAlwaysOnTop" HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="#992A2A2E" BorderBrush="#50505A" BorderThickness="1"
                                CornerRadius="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsBehavior}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}"
                                           Margin="14,10,14,2"/>
                                <Border Padding="14,9" BorderBrush="#2E2E36" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsAutoPaste}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center" Margin="0,0,40,0"/>
                                        <CheckBox x:Name="ChkAutoPaste" HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border Padding="14,9" BorderBrush="#2E2E36" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsAutoFetch}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center" Margin="0,0,40,0"/>
                                        <CheckBox x:Name="ChkAutoFetch" HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border Padding="14,9">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsNotifyComplete}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center" Margin="0,0,40,0"/>
                                        <CheckBox x:Name="ChkNotifyComplete" HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Upload Tab ── -->
                    <StackPanel x:Name="PanelUpload" Visibility="Collapsed">
                        <Border Background="#992A2A2E" BorderBrush="#50505A" BorderThickness="1"
                                CornerRadius="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsYoutubeDefaults}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}"
                                           Margin="14,10,14,2"/>
                                <Border Padding="14,9" BorderBrush="#2E2E36" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsDefaultPrivacy}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox x:Name="CmbDefaultPrivacy" HorizontalAlignment="Right"
                                                  Width="140" SelectedIndex="0">
                                            <ComboBoxItem Content="{DynamicResource PrivacyPublic}" Tag="public"/>
                                            <ComboBoxItem Content="{DynamicResource PrivacyUnlisted}" Tag="unlisted"/>
                                            <ComboBoxItem Content="{DynamicResource PrivacyPrivate}" Tag="private"/>
                                        </ComboBox>
                                    </Grid>
                                </Border>
                                <Border Padding="14,9">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsAutoShorts}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center" Margin="0,0,40,0"/>
                                        <CheckBox x:Name="ChkAutoShorts" HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="#992A2A2E" BorderBrush="#50505A" BorderThickness="1"
                                CornerRadius="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsFingerprintBypass}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}"
                                           Margin="14,10,14,2"/>
                                <Border Padding="14,9" BorderBrush="#2E2E36" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsFpEnable}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox x:Name="ChkDefaultFp" HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border Padding="14,9">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsFpMethod}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox x:Name="CmbDefaultFpMethod" HorizontalAlignment="Right"
                                                  Width="140" SelectedIndex="2"
                                                  IsEnabled="{Binding IsChecked, ElementName=ChkDefaultFp}">
                                            <ComboBoxItem Content="{DynamicResource FpMetadata}" Tag="metadata"/>
                                            <ComboBoxItem Content="{DynamicResource FpLight}" Tag="light"/>
                                            <ComboBoxItem Content="{DynamicResource FpStandard}" Tag="standard"/>
                                            <ComboBoxItem Content="{DynamicResource FpStrong}" Tag="strong"/>
                                        </ComboBox>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Download Tab ── -->
                    <StackPanel x:Name="PanelDownload" Visibility="Collapsed">
                        <Border Background="#992A2A2E" BorderBrush="#50505A" BorderThickness="1"
                                CornerRadius="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsSaveLocation}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}"
                                           Margin="14,10,14,2"/>
                                <Border Padding="14,9">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtDefaultOutputDir" IsReadOnly="True"
                                                 VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Style="{StaticResource OutlineBtn}"
                                                Content="{DynamicResource BtnBrowse}"
                                                Margin="8,0,0,0" Click="BrowseOutput_Click"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="#992A2A2E" BorderBrush="#50505A" BorderThickness="1"
                                CornerRadius="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsQualitySection}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}"
                                           Margin="14,10,14,2"/>
                                <Border Padding="14,9">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsVideoQuality}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox x:Name="CmbVideoQuality" HorizontalAlignment="Right"
                                                  Width="140" SelectedIndex="0">
                                            <ComboBoxItem Content="{DynamicResource QualityBest}" Tag="best"/>
                                            <ComboBoxItem Content="1080p" Tag="1080p"/>
                                            <ComboBoxItem Content="720p" Tag="720p"/>
                                            <ComboBoxItem Content="480p" Tag="480p"/>
                                        </ComboBox>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="#992A2A2E" BorderBrush="#50505A" BorderThickness="1"
                                CornerRadius="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsFingerprintBypass}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}"
                                           Margin="14,10,14,2"/>
                                <Border Padding="14,9" BorderBrush="#2E2E36" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsFpEnable}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox x:Name="ChkDefaultFpDl" HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border Padding="14,9">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsFpMethod}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox x:Name="CmbDefaultFpMethodDl" HorizontalAlignment="Right"
                                                  Width="140" SelectedIndex="2"
                                                  IsEnabled="{Binding IsChecked, ElementName=ChkDefaultFpDl}">
                                            <ComboBoxItem Content="{DynamicResource FpMetadata}" Tag="metadata"/>
                                            <ComboBoxItem Content="{DynamicResource FpLight}" Tag="light"/>
                                            <ComboBoxItem Content="{DynamicResource FpStandard}" Tag="standard"/>
                                            <ComboBoxItem Content="{DynamicResource FpStrong}" Tag="strong"/>
                                        </ComboBox>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Advanced Tab ── -->
                    <StackPanel x:Name="PanelAdvanced" Visibility="Collapsed">
                        <Border Background="#992A2A2E" BorderBrush="#50505A" BorderThickness="1"
                                CornerRadius="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsPerformance}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}"
                                           Margin="14,10,14,2"/>
                                <Border Padding="14,9" BorderBrush="#2E2E36" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsUseGpu}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center" Margin="0,0,40,0"/>
                                        <CheckBox x:Name="ChkUseGpu" HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border Padding="14,9">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsMaxJobs}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox x:Name="CmbMaxJobs" HorizontalAlignment="Right"
                                                  Width="80" SelectedIndex="0">
                                            <ComboBoxItem Content="1" Tag="1"/>
                                            <ComboBoxItem Content="2" Tag="2"/>
                                            <ComboBoxItem Content="3" Tag="3"/>
                                            <ComboBoxItem Content="4" Tag="4"/>
                                        </ComboBox>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="#992A2A2E" BorderBrush="#50505A" BorderThickness="1"
                                CornerRadius="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsBackend}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}"
                                           Margin="14,10,14,2"/>
                                <Border Padding="14,9" BorderBrush="#2E2E36" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource SettingsBackendUrl}"
                                                   FontSize="11" Foreground="{StaticResource TextSec}"
                                                   Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtBackendUrl"/>
                                    </StackPanel>
                                </Border>
                                <Border Padding="14,9">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource SettingsBackendTimeout}"
                                                   FontSize="11" Foreground="{StaticResource TextSec}"
                                                   Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtBackendTimeout"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="#992A2A2E" BorderBrush="#50505A" BorderThickness="1"
                                CornerRadius="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsDeveloper}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}"
                                           Margin="14,10,14,2"/>
                                <Border Padding="14,9">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource SettingsDevConsole}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                                   VerticalAlignment="Center" Margin="0,0,40,0"/>
                                        <CheckBox x:Name="ChkDevConsole" HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Button Style="{StaticResource OutlineBtn}"
                                Content="{DynamicResource SettingsResetAll}"
                                Foreground="{StaticResource ErrorRed}"
                                BorderBrush="#50505A"
                                HorizontalAlignment="Left" Margin="0,2,0,6"
                                Click="ResetAll_Click"/>
                    </StackPanel>

                </Grid>
            </ScrollViewer>

            <!-- ═══ Footer ═══ -->
            <Border Grid.Row="3" BorderBrush="#2A2A2F" BorderThickness="0,1,0,0">
                <Grid Margin="14,10,14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="v3.0" FontSize="10"
                               Foreground="{StaticResource TextSec}"
                               VerticalAlignment="Center" Opacity="0.5"/>
                    <Button Grid.Column="2"
                            Content="{DynamicResource BtnCancelSettings}"
                            Style="{StaticResource OutlineBtn}"
                            Margin="0,0,8,0"
                            Click="Cancel_Click"/>
                    <Button Grid.Column="3"
                            Content="{DynamicResource BtnSaveSettings}"
                            Style="{StaticResource GradBtn}" Width="100"
                            Click="Save_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
