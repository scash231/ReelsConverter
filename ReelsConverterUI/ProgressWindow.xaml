<Window x:Class="ReelsConverterUI.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fortschritt" Width="420" Height="175"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="8"
            Background="{StaticResource BgDeep}"
            BorderBrush="{StaticResource BorderSub}" BorderThickness="1"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="WinScale"/>
        </Border.RenderTransform>

        <Border.Triggers>
            <EventTrigger RoutedEvent="Border.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="WinScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         From="0.96" To="1" Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="WinScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         From="0.96" To="1" Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#141416" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_Drag">
                <TextBlock Text="Fortschritt" FontWeight="SemiBold"
                           FontSize="12" Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Border>

            <!-- Progress content -->
            <StackPanel Grid.Row="1" Margin="16,12,16,0">
                <Grid Margin="0,0,0,8">
                    <TextBlock x:Name="TxtProgressMsg" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TxtProgressPct" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource Accent}"
                               HorizontalAlignment="Right"/>
                </Grid>

                <Border x:Name="ProgressTrack" Height="6" CornerRadius="3"
                        Background="{StaticResource BgElevated}">
                    <Border x:Name="ProgressFill" CornerRadius="3"
                            HorizontalAlignment="Left" Width="0">
                        <Border.Background>
                            <SolidColorBrush Color="#7A9EC0"/>
                        </Border.Background>
                    </Border>
                </Border>

                <TextBlock x:Name="TxtProgressDetail" FontSize="11"
                           Foreground="{StaticResource TextSec}" Margin="0,6,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Cancel / Close button -->
            <Button x:Name="BtnCancel" Grid.Row="2"
                    Content="Abbrechen" Style="{StaticResource OutlineBtn}"
                    HorizontalAlignment="Right" Margin="0,8,16,12"
                    Click="Cancel_Click"/>
        </Grid>
    </Border>
</Window>
