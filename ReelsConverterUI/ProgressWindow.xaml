<Window x:Class="ReelsConverterUI.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fortschritt" Width="420"
        SizeToContent="Height"
        Icon="app.ico"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border x:Name="RootBorder" CornerRadius="16"
            Background="{StaticResource BgDeep}"
            BorderBrush="{StaticResource BorderSub}" BorderThickness="1"
            Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="WinScale"/>
                <TranslateTransform x:Name="WinTranslate"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#141416" CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_Drag">
                <TextBlock Text="Fortschritt" FontWeight="SemiBold"
                           FontSize="12" Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Border>

            <!-- Progress content -->
            <StackPanel Grid.Row="1" Margin="16,12,16,0">
                <Grid x:Name="RowMsgPct" Margin="0,0,0,8">
                    <TextBlock x:Name="TxtProgressMsg"
                               Foreground="{StaticResource TextPrimary}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TxtProgressPct" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource Accent}"
                               HorizontalAlignment="Right"/>
                </Grid>

                <Border x:Name="ProgressTrack" Height="6" CornerRadius="3"
                        Background="{StaticResource BgElevated}">
                    <Border x:Name="ProgressFill" CornerRadius="3"
                            HorizontalAlignment="Left" Width="0">
                        <Border.Background>
                            <SolidColorBrush Color="#7A9EC0"/>
                        </Border.Background>
                    </Border>
                </Border>

                <Grid x:Name="RowDetail" Margin="0,6,0,0">
                    <TextBlock x:Name="TxtEta" FontSize="11"
                               Foreground="{StaticResource TextSec}"
                               HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtProgressDetail"
                               Foreground="{StaticResource TextSec}"
                               TextTrimming="CharacterEllipsis"
                               Margin="55,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- Footer row: countdown + open folder + console toggle + button -->
            <Grid Grid.Row="2" Margin="16,8,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtCountdown" FontSize="11"
                           Foreground="{StaticResource TextSec}"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
                <Button x:Name="BtnOpenFolder" Grid.Column="1"
                        Content="📂 Open Folder" Style="{StaticResource OutlineBtn}"
                        Margin="0,0,6,0"
                        Visibility="Collapsed"
                        Click="OpenFolder_Click"/>
                <Button x:Name="BtnToggleLog" Grid.Column="2"
                        Content="▾ Log" Style="{StaticResource OutlineBtn}"
                        Margin="0,0,6,0"
                        Click="ToggleLog_Click"/>
                <Button x:Name="BtnCancel" Grid.Column="3"
                        Content="Abbrechen" Style="{StaticResource OutlineBtn}"
                        Click="Cancel_Click"/>
            </Grid>

            <!-- Console (toggleable) -->
            <TextBox x:Name="TxtConsole" Grid.Row="3"
                     Margin="16,0,16,12"
                     Background="#0D0D0F"
                     BorderBrush="{StaticResource BorderSub}" BorderThickness="1"
                     Foreground="#7A9EC0"
                     FontFamily="Consolas"
                     FontSize="10"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     MaxHeight="140"
                     Padding="8,6"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     Visibility="Collapsed"/>
        </Grid>
    </Border>
</Window>
