<Window x:Class="ReelsConverterUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ReelsConverter" Width="760" Height="560"
        MinWidth="600" MinHeight="480"
        Icon="app.ico"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">

    <!-- ═══════════════════ WINDOW RESOURCES ═══════════════════ -->
    <Window.Resources>
        <Storyboard x:Key="FadeInWindow">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="WindowScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.88" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="8"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="WindowScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.85" To="1" Duration="0:0:0.52"
                             BeginTime="0:0:0.035">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="8"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInWindow}"/>
        </EventTrigger>
    </Window.Triggers>

    <!-- ═══════════════════ ROOT BORDER ═══════════════════ -->
    <Border x:Name="RootBorder" CornerRadius="16"
            Background="{StaticResource BgDeep}"
            BorderBrush="{StaticResource BorderSub}" BorderThickness="0.5"
            Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="WindowScale"/>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Dev Console -->
                <RowDefinition Height="30"/>   <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ═══════════ TITLE BAR ═══════════ -->
            <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="VideoConverter" FontWeight="SemiBold"
                                   FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text=" v3" FontSize="9"
                                   Foreground="{StaticResource TextSec}"
                                   VerticalAlignment="Center" Margin="4,1,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
                        <!-- Help / Workflow -->
                        <Button x:Name="BtnHelp"
                                Style="{StaticResource IconBtn}"
                                Foreground="{StaticResource TextSec}"
                                Width="30" Height="30" Margin="0,0,2,0"
                                ToolTip="Workflow"
                                Click="Help_Click">
                            <TextBlock Text="?" FontSize="13" FontWeight="Bold"/>
                        </Button>
                        <!-- Theme Designer -->
                        <Button Style="{StaticResource IconBtn}"
                                Foreground="{StaticResource TextSec}"
                                Width="30" Height="30" Margin="0,0,2,0"
                                ToolTip="{DynamicResource TipDesigner}"
                                Click="Designer_Click">
                            <TextBlock Text="🎨" FontSize="12"/>
                        </Button>
                        <!-- Video Editor -->
                        <Button Style="{StaticResource IconBtn}"
                                Foreground="{StaticResource TextSec}"
                                Width="30" Height="30" Margin="0,0,2,0"
                                ToolTip="{DynamicResource TipEditor}"
                                Click="Editor_Click">
                            <TextBlock Text="✂" FontSize="12"/>
                        </Button>
                        <!-- Settings -->
                        <Button Style="{StaticResource IconBtn}"
                                Foreground="{StaticResource TextSec}"
                                Width="30" Height="30" Margin="0,0,2,0"
                                ToolTip="{DynamicResource TipSettings}"
                                Click="Settings_Click">
                            <TextBlock Text="⚙" FontSize="14"/>
                        </Button>
                        <!-- Language Toggle -->
                        <Border VerticalAlignment="Center" Margin="0,0,6,0"
                                BorderBrush="{StaticResource BorderSub}"
                                BorderThickness="1" CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnLangDE" Content="DE"
                                        Style="{StaticResource IconBtn}"
                                        Foreground="{StaticResource Accent}"
                                        FontSize="10" FontWeight="SemiBold"
                                        Width="28" Height="22"
                                        Click="LangDE_Click"/>
                                <Border Width="1" Background="{StaticResource BorderSub}" Margin="0,5"/>
                                <Button x:Name="BtnLangEN" Content="EN"
                                        Style="{StaticResource IconBtn}"
                                        Foreground="{StaticResource TextSec}"
                                        FontSize="10" FontWeight="SemiBold"
                                        Width="28" Height="22"
                                        Click="LangEN_Click"/>
                            </StackPanel>
                        </Border>
                        <Button Style="{StaticResource IconBtn}"
                                Foreground="{StaticResource TextSec}" Width="30" Height="30"
                                Click="Minimize_Click">
                            <TextBlock Text="─" FontSize="12"/>
                        </Button>
                        <Button Style="{StaticResource IconBtn}"
                                Foreground="{StaticResource ErrorRed}" Width="30" Height="30"
                                Click="Close_Click">
                            <TextBlock Text="✕" FontSize="11"/>
                        </Button>
                    </StackPanel>
                    <Popup x:Name="HelpPopup"
                           Placement="Bottom"
                           VerticalOffset="4"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="None">
                        <Border x:Name="HelpPopupBorder"
                                Background="#A8202024"
                                BorderBrush="#30FFFFFF" BorderThickness="0.5"
                                CornerRadius="12"
                                Padding="14,12" MinWidth="200"
                                Opacity="0" RenderTransformOrigin="0.5,0">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                    <TranslateTransform Y="-4"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <StackPanel>
                                <TextBlock Text="Workflow" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="①" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource Accent}" Width="18"/>
                                    <TextBlock Text="{DynamicResource Step1}" FontSize="11"
                                               Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="②" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource Accent}" Width="18"/>
                                    <TextBlock Text="{DynamicResource Step2}" FontSize="11"
                                               Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="③" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource Accent}" Width="18"/>
                                    <TextBlock Text="{DynamicResource Step3}" FontSize="11"
                                               Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Border>

            <!-- ═══════════ MAIN CONTENT ═══════════ -->
            <Grid Grid.Row="1" Margin="14,6,14,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ──── URL BAR (full-width) ──── -->
				<Grid Grid.Row="0" Margin="0,0,0,8">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<TextBox x:Name="TxtUrl" VerticalAlignment="Center"
					Tag="{DynamicResource UrlPlaceholder}"
					TextChanged="TxtUrl_TextChanged"/>
					<Button Grid.Column="1" ToolTip="{DynamicResource TipPaste}"
					Style="{StaticResource IconBtn}"
					Foreground="{StaticResource TextSec}"
					Margin="6,0,0,0" Click="Paste_Click">
						<TextBlock Text="📋" FontSize="14"/>
					</Button>
					<Button Grid.Column="2" Content="{DynamicResource BtnFetch}"
					Style="{StaticResource OutlineBtn}"
					Margin="4,0,0,0" x:Name="BtnFetch"
					Click="Fetch_Click"/>
				</Grid>
				
				<!-- ──── MODE TOGGLE (iOS 26 segmented control) ──── -->
                <Border x:Name="SegmentTrack" Grid.Row="1" CornerRadius="50" Padding="3"
                        Background="{StaticResource BgCard}"
                        BorderBrush="#18FFFFFF" BorderThickness="0.5"
                        Margin="0,0,0,8" Cursor="Hand"
                        PreviewMouseLeftButtonDown="Segment_PreviewMouseDown"
                        PreviewMouseMove="Segment_PreviewMouseMove"
                        PreviewMouseLeftButtonUp="Segment_PreviewMouseUp">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Animated pill indicator -->
                        <Border x:Name="SegmentIndicator" Grid.Column="0"
                                CornerRadius="50" Background="#2A2A30"
                                BorderBrush="#30FFFFFF" BorderThickness="1"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="SegmentScale"/>
                                    <TranslateTransform x:Name="SegmentTranslateX"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                        </Border>
                        <RadioButton x:Name="RbUpload" Style="{StaticResource SegmentedBtn}"
                                     GroupName="Mode" IsChecked="True"
                                     Checked="Mode_Changed">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="☁" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource ModeUploadTitle}"
                                           FontWeight="SemiBold" FontSize="12"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Grid.Column="1" x:Name="RbDownload"
                                     Style="{StaticResource SegmentedBtn}"
                                     GroupName="Mode" Checked="Mode_Changed">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="💾" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource ModeDownloadTitle}"
                                           FontWeight="SemiBold" FontSize="12"/>
                            </StackPanel>
                        </RadioButton>
                    </Grid>
                </Border>

                <!-- ──── Two-column layout ──── -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ═══ LEFT: Preview ═══ -->
                    <Grid Grid.Column="0">
                        <Border x:Name="BorderMeta" Style="{StaticResource Card}"
                                Visibility="Collapsed" Opacity="0" Padding="0"
                                ClipToBounds="True" Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <!-- Thumbnail -->
                                    <Border x:Name="ThumbBgBorder" CornerRadius="16,16,0,0"
                                            Background="{StaticResource BgElevated}"
                                            ClipToBounds="True" MaxHeight="150">
                                        <Grid>
                                            <TextBlock x:Name="TxtMetaThumbFallback" Text="🎥"
                                                       FontSize="36" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Image x:Name="ImgThumbnail" Stretch="UniformToFill"
                                                   VerticalAlignment="Center"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <!-- 10% darken overlay -->
                                            <Border Background="#1A000000"/>
                                        </Grid>
                                    </Border>
                                    <!-- Info -->
                                    <StackPanel Margin="12,8,12,4">
                                        <TextBlock x:Name="TxtMetaTitle" FontWeight="SemiBold"
                                                   FontSize="11.5"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   TextWrapping="Wrap" MaxHeight="32"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock x:Name="TxtMetaUploader" FontSize="10"
                                                       Foreground="{StaticResource TextSec}"/>
                                            <TextBlock x:Name="TxtMetaDuration" FontSize="10"
                                                       Foreground="{StaticResource TextSec}"
                                                       Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <ItemsControl x:Name="TagsList" Margin="0,5,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="7" Padding="6,2"
                                                            Margin="0,0,3,3"
                                                            Background="{StaticResource BgElevated}">
                                                        <TextBlock Text="{Binding}" FontSize="9"
                                                                   Foreground="{StaticResource Accent}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Quick actions (integrated card footer) -->
                                <Border Grid.Row="1"
                                        BorderBrush="{StaticResource BorderSub}"
                                        BorderThickness="0,0.5,0,0" Padding="8,5">
                                    <DockPanel>
                                        <Button Style="{StaticResource IconBtn}" DockPanel.Dock="Right"
                                                Click="ClearForm_Click" Padding="4,3"
                                                ToolTip="{DynamicResource TipClearForm}">
                                            <TextBlock Text="✕" FontSize="10"
                                                       Foreground="{StaticResource TextSec}"/>
                                        </Button>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource IconBtn}" Padding="4,3"
                                                    Click="CopyTitle_Click" ToolTip="Copy title">
                                                <TextBlock Text="📝" FontSize="12"/>
                                            </Button>
                                            <Button Style="{StaticResource IconBtn}" Padding="4,3"
                                                    Margin="1,0,0,0"
                                                    Click="CopyUrl_Click" ToolTip="Copy URL">
                                                <TextBlock Text="🔗" FontSize="12"/>
                                            </Button>
                                            <Button Style="{StaticResource IconBtn}" Padding="4,3"
                                                    Margin="1,0,0,0"
                                                    Click="OpenInBrowser_Click"
                                                    ToolTip="Open in browser">
                                                <TextBlock Text="🌐" FontSize="12"/>
                                            </Button>
                                            <Button Style="{StaticResource IconBtn}" Padding="4,3"
                                                    Margin="1,0,0,0"
                                                    Click="SaveThumbnail_Click"
                                                    ToolTip="Save thumbnail">
                                                <TextBlock Text="💾" FontSize="12"/>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ═══ RIGHT: Settings ═══ -->
                    <StackPanel Grid.Column="2">

                        <!-- UPLOAD SETTINGS -->
                        <Border x:Name="BorderUpload" Style="{StaticResource Card}"
                                Background="#D9202024"
                                Visibility="Collapsed" Opacity="0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LblTitleField}" FontSize="10"
                                           Foreground="{StaticResource TextSec}" Margin="0,0,0,3"/>
                                <TextBox x:Name="TxtTitle"/>
                                <Grid Margin="0,8,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LblDescField}" FontSize="10"
                                               Foreground="{StaticResource TextSec}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Style="{StaticResource IconBtn}"
                                            ToolTip="{DynamicResource TipEditDesc}"
                                            Click="EditDescription_Click">
                                        <TextBlock Text="✏" FontSize="12"
                                                   Foreground="{StaticResource TextSec}"/>
                                    </Button>
                                </Grid>
                                <TextBox x:Name="TxtDescription" IsReadOnly="True"
                                         TextWrapping="Wrap" Height="56"
                                         VerticalScrollBarVisibility="Auto"
                                         ToolTip="{DynamicResource TipDescBox}"
                                         MouseDoubleClick="EditDescription_Click"/>
                                <TextBlock Text="{DynamicResource LblVisibility}" FontSize="10"
                                           Foreground="{StaticResource TextSec}" Margin="0,8,0,3"/>
                                <ComboBox x:Name="CmbPrivacy" SelectedIndex="0">
                                    <ComboBoxItem Content="{DynamicResource PrivacyPublic}"   Tag="public"/>
                                    <ComboBoxItem Content="{DynamicResource PrivacyUnlisted}" Tag="unlisted"/>
                                    <ComboBoxItem Content="{DynamicResource PrivacyPrivate}"  Tag="private"/>
                                </ComboBox>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ChkFingerprint" IsChecked="True"
                                              Foreground="{StaticResource TextSec}"
                                              Content="Fingerprint" FontSize="10"
                                              VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CmbFingerprintMethod" Grid.Column="1"
                                              Margin="8,0,0,0" SelectedIndex="2"
                                              IsEnabled="{Binding IsChecked, ElementName=ChkFingerprint}">
                                        <ComboBoxItem Content="{DynamicResource FpMetadata}" Tag="metadata"/>
                                        <ComboBoxItem Content="{DynamicResource FpLight}"    Tag="light"/>
                                        <ComboBoxItem Content="{DynamicResource FpStandard}" Tag="standard"/>
                                        <ComboBoxItem Content="{DynamicResource FpStrong}"   Tag="strong"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- DOWNLOAD SETTINGS -->
                        <Border x:Name="BorderDownload" Style="{StaticResource Card}"
                                Background="#D9202024"
                                Visibility="Collapsed" Opacity="0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LblDlTitle}" FontSize="10"
                                           Foreground="{StaticResource TextSec}" Margin="0,0,0,3"/>
                                <TextBox x:Name="TxtTitleDl"
                                         Tag="{DynamicResource DlTitlePlaceholder}"/>
                                <TextBlock Text="{DynamicResource LblQuality}" FontSize="10"
                                           Foreground="{StaticResource TextSec}" Margin="0,8,0,3"/>
                                <ComboBox x:Name="CmbQuality" SelectedIndex="0">
                                    <ComboBoxItem Content="{DynamicResource QualityBest}" Tag="best"/>
                                    <ComboBoxItem Content="1080p" Tag="1080"/>
                                    <ComboBoxItem Content="720p" Tag="720"/>
                                    <ComboBoxItem Content="480p" Tag="480"/>
                                    <ComboBoxItem Content="360p" Tag="360"/>
                                    <ComboBoxItem Content="{DynamicResource QualityAudio}" Tag="audio"/>
                                </ComboBox>
                                <TextBlock Text="{DynamicResource LblSavePath}" FontSize="10"
                                           Foreground="{StaticResource TextSec}" Margin="0,0,0,3"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtOutputDir" IsReadOnly="True"/>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource OutlineBtn}"
                                            Content="{DynamicResource BtnBrowse}"
                                            Margin="8,0,0,0" Click="Browse_Click"/>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ChkFingerprintDl" IsChecked="True"
                                              Foreground="{StaticResource TextSec}"
                                              Content="Fingerprint" FontSize="10"
                                              VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CmbFingerprintMethodDl" Grid.Column="1"
                                              Margin="8,0,0,0" SelectedIndex="2"
                                              IsEnabled="{Binding IsChecked, ElementName=ChkFingerprintDl}">
                                        <ComboBoxItem Content="{DynamicResource FpMetadata}" Tag="metadata"/>
                                        <ComboBoxItem Content="{DynamicResource FpLight}"    Tag="light"/>
                                        <ComboBoxItem Content="{DynamicResource FpStandard}" Tag="standard"/>
                                        <ComboBoxItem Content="{DynamicResource FpStrong}"   Tag="strong"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- OPEN FILE LOCATION (shown after successful job) -->
                        <Button x:Name="BtnOpenFileLocation"
                                Visibility="Collapsed" Opacity="0"
                                Margin="0,2,0,0" Height="36"
                                Click="OpenFileLocation_Click"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="12" Padding="12,0"
                                            BorderBrush="#205AAF6E" BorderThickness="0.5"
                                            Background="#18405A48">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="📂" FontSize="13" Margin="0,0,8,0"/>
                                            <TextBlock Text="{DynamicResource BtnOpenFileLocation}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource SuccessGreen}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#24405A48"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#30405A48"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </Grid>

                <!-- START BUTTON + LOG -->
                <Grid Grid.Row="3" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnStart" Style="{StaticResource GradBtn}"
                            Content="{DynamicResource BtnStart}"
                            Click="Start_Click"/>
                    <Button x:Name="BtnMainLog" Grid.Column="1"
                            Style="{StaticResource GlassPillBtn}"
                            Margin="8,0,0,0" IsEnabled="False"
                            Visibility="Collapsed"
                            VerticalAlignment="Stretch"
                            Click="MainLog_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" FontSize="10" Margin="0,0,4,0"/>
                            <TextBlock Text="Log"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- ═══════════ DEV CONSOLE ═══════════ -->
            <Border x:Name="BorderDevConsole" Grid.Row="2" Visibility="Collapsed"
                    Background="#0A0A0C" BorderBrush="{StaticResource BorderSub}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition x:Name="DevConsoleContentRow" Height="120"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#111113" Padding="10,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⌘" FontSize="10" Foreground="{StaticResource Accent}"
                                           Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource DevConsoleTitle}" FontSize="9"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnDevConsoleHelp"
                                        Style="{StaticResource IconBtn}"
                                        Width="22" Height="22" Margin="0,0,2,0"
                                        Click="DevConsoleHelp_Click"
                                        ToolTip="{DynamicResource DevConsoleHelpTip}">
                                    <TextBlock Text="?" FontSize="9" FontWeight="Bold"/>
                                </Button>
                                <Button Style="{StaticResource IconBtn}"
                                        Width="22" Height="22" Margin="0,0,2,0"
                                        Click="CollapseDevConsole_Click"
                                        ToolTip="{DynamicResource DevConsoleCollapse}">
                                    <TextBlock x:Name="TxtCollapseIcon" Text="▾" FontSize="9"/>
                                </Button>
                                <Button Style="{StaticResource IconBtn}"
                                        Width="22" Height="22" Margin="0,0,2,0"
                                        Click="DetachDevConsole_Click"
                                        ToolTip="{DynamicResource DevConsoleDetach}">
                                    <TextBlock Text="🗗" FontSize="9"/>
                                </Button>
                                <Button Style="{StaticResource IconBtn}"
                                        Width="22" Height="22"
                                        Click="ClearDevConsole_Click"
                                        ToolTip="{DynamicResource DevConsoleClear}">
                                    <TextBlock Text="🗑" FontSize="9"/>
                                </Button>
                            </StackPanel>
                            <Popup x:Name="DevConsoleHelpPopup"
                                   Placement="Bottom"
                                   VerticalOffset="4"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="None">
                                <Border x:Name="DevHelpPopupBorder"
                                        Background="#A8202024"
                                        BorderBrush="#30FFFFFF" BorderThickness="0.5"
                                        CornerRadius="12"
                                        Padding="14,12" MinWidth="220"
                                        Opacity="0" RenderTransformOrigin="0.5,0">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                            <TranslateTransform Y="-4"/>
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource DevConsoleHelpTitle}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSec}" Margin="0,0,0,8"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{StaticResource Accent}" Text="help"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock FontSize="10" Foreground="{StaticResource TextPrimary}"
                                                   Text="{DynamicResource CmdHelpDesc}" Margin="0,0,0,6"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{StaticResource Accent}" Text="clear / cls"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock FontSize="10" Foreground="{StaticResource TextPrimary}"
                                                   Text="{DynamicResource CmdClearDesc}" Margin="0,0,0,6"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{StaticResource Accent}" Text="status"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock FontSize="10" Foreground="{StaticResource TextPrimary}"
                                                   Text="{DynamicResource CmdStatusDesc}" Margin="0,0,0,6"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                   Foreground="{StaticResource Accent}" Text="info"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock FontSize="10" Foreground="{StaticResource TextPrimary}"
                                                   Text="{DynamicResource CmdInfoDesc}" Margin="0,0,0,6"/>
                                        <Border Height="1" Background="{StaticResource BorderSub}" Margin="0,2,0,6"/>
                                        <TextBlock FontSize="10" Foreground="{StaticResource TextSec}"
                                                   Text="{DynamicResource CmdFallbackDesc}"
                                                   TextWrapping="Wrap" FontStyle="Italic"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <Grid x:Name="DevConsoleBody" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBox x:Name="TxtDevConsole" Grid.Row="0"
                                 Background="#0A0A0C" BorderThickness="0"
                                 Foreground="#5A8A5A" FontFamily="Consolas" FontSize="10"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" Padding="10,6"/>
                        <Border Grid.Row="1" Background="#111113"
                                BorderBrush="{StaticResource BorderSub}"
                                BorderThickness="0,1,0,0" Padding="6,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="›" FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource Accent}"
                                           VerticalAlignment="Center" Margin="4,0,6,0"/>
                                <TextBox x:Name="TxtDevConsoleInput" Grid.Column="1"
                                         Background="#0A0A0C" BorderThickness="0"
                                         Foreground="#C0C0C0" FontFamily="Consolas" FontSize="10"
                                         CaretBrush="#C0C0C0" Padding="4,3"
                                         KeyDown="TxtDevConsoleInput_KeyDown"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ═══════════ STATUS BAR ═══════════ -->
            <Border Grid.Row="3" Background="{StaticResource BgDeep}"
                    CornerRadius="0,0,16,16" Padding="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="6" Height="6" Margin="0,0,6,0">
                        <Ellipse.Fill>
                            <SolidColorBrush x:Name="StatusDotColor" Color="#5AAF6E"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock x:Name="TxtStatusBar" Text="{DynamicResource StatusStarting}"
                               FontSize="10" Foreground="{StaticResource TextSec}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
