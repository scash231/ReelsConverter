<Window x:Class="ReelsConverterUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ReelsConverter" Width="760" Height="560"
        MinWidth="600" MinHeight="480"
        Icon="app.ico"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">

    <!-- ═══════════════════ WINDOW RESOURCES ═══════════════════ -->
    <Window.Resources>
        <Storyboard x:Key="FadeInWindow">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="WindowScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.96" To="1" Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="WindowScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.96" To="1" Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInWindow}"/>
        </EventTrigger>
    </Window.Triggers>

    <!-- ═══════════════════ ROOT BORDER ═══════════════════ -->
    <Border x:Name="RootBorder" CornerRadius="8"
            Background="{StaticResource BgDeep}"
            BorderBrush="{StaticResource BorderSub}" BorderThickness="1"
            Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="WindowScale"/>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="28"/>   <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ═══════════ TITLE BAR ═══════════ -->
            <Border Grid.Row="0" Background="#141416"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="ReelsConverter" FontWeight="SemiBold"
                                   FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text=" v2.0" FontSize="9"
                                   Foreground="{StaticResource TextSec}"
                                   VerticalAlignment="Center" Margin="4,1,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
                        <!-- Help / Workflow -->
                        <Button x:Name="BtnHelp"
                                Style="{StaticResource IconBtn}"
                                Foreground="{StaticResource TextSec}"
                                Width="30" Height="30" Margin="0,0,2,0"
                                ToolTip="Workflow"
                                Click="Help_Click">
                            <TextBlock Text="?" FontSize="13" FontWeight="Bold"/>
                        </Button>
                        <!-- Settings -->
                        <Button Style="{StaticResource IconBtn}"
                                Foreground="{StaticResource TextSec}"
                                Width="30" Height="30" Margin="0,0,2,0"
                                ToolTip="{DynamicResource TipSettings}"
                                Click="Settings_Click">
                            <TextBlock Text="⚙" FontSize="14"/>
                        </Button>
                        <!-- Language Toggle -->
                        <Border VerticalAlignment="Center" Margin="0,0,6,0"
                                BorderBrush="{StaticResource BorderSub}"
                                BorderThickness="1" CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnLangDE" Content="DE"
                                        Style="{StaticResource IconBtn}"
                                        Foreground="{StaticResource Accent}"
                                        FontSize="10" FontWeight="SemiBold"
                                        Width="28" Height="22"
                                        Click="LangDE_Click"/>
                                <Border Width="1" Background="{StaticResource BorderSub}" Margin="0,5"/>
                                <Button x:Name="BtnLangEN" Content="EN"
                                        Style="{StaticResource IconBtn}"
                                        Foreground="{StaticResource TextSec}"
                                        FontSize="10" FontWeight="SemiBold"
                                        Width="28" Height="22"
                                        Click="LangEN_Click"/>
                            </StackPanel>
                        </Border>
                        <Button Style="{StaticResource IconBtn}"
                                Foreground="{StaticResource TextSec}" Width="30" Height="30"
                                Click="Minimize_Click">
                            <TextBlock Text="─" FontSize="12"/>
                        </Button>
                        <Button Style="{StaticResource IconBtn}"
                                Foreground="{StaticResource ErrorRed}" Width="30" Height="30"
                                Click="Close_Click">
                            <TextBlock Text="✕" FontSize="11"/>
                        </Button>
                    </StackPanel>
                    <Popup x:Name="HelpPopup"
                           Placement="Bottom"
                           VerticalOffset="4"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{StaticResource BgElevated}"
                                BorderBrush="{StaticResource BorderSub}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="14,12" MinWidth="200">
                            <StackPanel>
                                <TextBlock Text="Workflow" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSec}" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="①" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource Accent}" Width="18"/>
                                    <TextBlock Text="{DynamicResource Step1}" FontSize="11"
                                               Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="②" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource Accent}" Width="18"/>
                                    <TextBlock Text="{DynamicResource Step2}" FontSize="11"
                                               Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="③" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource Accent}" Width="18"/>
                                    <TextBlock Text="{DynamicResource Step3}" FontSize="11"
                                               Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Border>

            <!-- ═══════════ MAIN CONTENT (two-column grid) ═══════════ -->
            <Grid Grid.Row="1" Margin="12,8,12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ──── Two-column layout ──── -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ═══ LEFT COLUMN: Platform, URL, Metadata ═══ -->
                    <ScrollViewer Grid.Column="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- TAB BAR -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Lbl}" Text="{DynamicResource SectionPlatform}"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="TabInsta" Style="{StaticResource TabBtn}"
                                                 Content="📷 Instagram" GroupName="Platform"
                                                 IsChecked="True" Checked="Tab_Changed"/>
                                    <RadioButton x:Name="TabTikTok" Style="{StaticResource TabBtn}"
                                                 Content="🎵 TikTok" GroupName="Platform"
                                                 Checked="Tab_Changed"/>
                                    <RadioButton x:Name="TabYouTube" Style="{StaticResource TabBtn}"
                                                 Content="▶ YouTube" GroupName="Platform"
                                                 Checked="Tab_Changed"/>
                                </StackPanel>
                                <Border x:Name="TabIndicator" Height="2" CornerRadius="1" Margin="0,6,0,0"
                                        HorizontalAlignment="Left" Width="80"
                                        Background="{StaticResource Accent}">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="TabIndicatorTranslate"/>
                                    </Border.RenderTransform>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- URL INPUT -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Lbl}" x:Name="LblUrl"
                                           Text="INSTAGRAM REEL URL"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtUrl" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" ToolTip="{DynamicResource TipPaste}"
                                            Style="{StaticResource IconBtn}"
                                            Foreground="{StaticResource TextSec}"
                                            Margin="8,0,0,0" Click="Paste_Click">
                                        <TextBlock Text="📋" FontSize="16"/>
                                    </Button>
                                    <Button Grid.Column="2" Content="{DynamicResource BtnFetch}"
                                            Style="{StaticResource OutlineBtn}"
                                            Margin="4,0,0,0" x:Name="BtnFetch"
                                            Click="Fetch_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- METADATA PREVIEW (hidden until fetched) -->
                        <Border x:Name="BorderMeta" Style="{StaticResource Card}"
                                Visibility="Collapsed" Opacity="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="56" Height="56" CornerRadius="6"
                                        Background="{StaticResource BgElevated}" Margin="0,0,14,0">
                                    <TextBlock Text="🎥" FontSize="28"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtMetaTitle" FontWeight="SemiBold"
                                               FontSize="12" Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="TxtMetaUploader" FontSize="12"
                                               Foreground="{StaticResource TextSec}" Margin="0,3,0,0"/>
                                    <TextBlock x:Name="TxtMetaDuration" FontSize="11"
                                               Foreground="{StaticResource TextSec}" Margin="0,2,0,0"/>
                                    <ItemsControl x:Name="TagsList" Margin="0,6,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="6,2"
                                                        Margin="0,0,4,4"
                                                        Background="{StaticResource BgElevated}">
                                                    <TextBlock Text="{Binding}" FontSize="10"
                                                               Foreground="{StaticResource Accent}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- QUICK ACTIONS (hidden until fetched) -->
                        <Border x:Name="BorderQuickActions" Style="{StaticResource Card}"
                                Visibility="Collapsed" Opacity="0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Lbl}"
                                           Text="{DynamicResource SectionQuickActions}"/>
                                <WrapPanel>
                                    <Button Style="{StaticResource OutlineBtn}"
                                            Margin="0,0,6,4" Click="CopyTitle_Click"
                                            Content="{DynamicResource BtnCopyTitle}"
                                            ToolTip="{DynamicResource TipCopyTitle}"/>
                                    <Button Style="{StaticResource OutlineBtn}"
                                            Margin="0,0,6,4" Click="CopyUrl_Click"
                                            Content="{DynamicResource BtnCopyUrl}"
                                            ToolTip="{DynamicResource TipCopyUrl}"/>
                                    <Button Style="{StaticResource OutlineBtn}"
                                            Margin="0,0,0,4" Click="OpenInBrowser_Click"
                                            Content="{DynamicResource BtnOpenBrowser}"
                                            ToolTip="{DynamicResource TipOpenBrowser}"/>
                                    <Button Style="{StaticResource OutlineBtn}"
                                            Margin="0,0,6,4" Click="CopyDesc_Click"
                                            Content="{DynamicResource BtnCopyDesc}"
                                            ToolTip="{DynamicResource TipCopyDesc}"/>
                                    <Button Style="{StaticResource OutlineBtn}"
                                            Margin="0,0,6,4" Click="CopyTags_Click"
                                            Content="{DynamicResource BtnCopyTags}"
                                            ToolTip="{DynamicResource TipCopyTags}"/>
                                    <Button Style="{StaticResource OutlineBtn}"
                                            Margin="0,0,0,4" Click="ClearForm_Click"
                                            Content="{DynamicResource BtnClearForm}"
                                            ToolTip="{DynamicResource TipClearForm}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                    </ScrollViewer>

                    <!-- ═══ RIGHT COLUMN: Mode, Settings ═══ -->
                    <StackPanel Grid.Column="2">

                        <!-- MODE SELECTION -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Lbl}" Text="{DynamicResource SectionAction}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton x:Name="RbUpload" Style="{StaticResource ModeCard}"
                                                 GroupName="Mode" IsChecked="True"
                                                 Checked="Mode_Changed">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="☁" FontSize="16" Margin="0,0,6,0"
                                                           Foreground="{StaticResource Accent}"/>
                                                <TextBlock Text="{DynamicResource ModeUploadTitle}" FontWeight="SemiBold"
                                                           FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Text="{DynamicResource ModeUploadDesc}"
                                                       FontSize="10" Foreground="{StaticResource TextSec}"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton Grid.Column="2" x:Name="RbDownload"
                                                 Style="{StaticResource ModeCard}"
                                                 GroupName="Mode" Checked="Mode_Changed">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="💾" FontSize="16" Margin="0,0,6,0"
                                                           Foreground="{StaticResource AccentPink}"/>
                                                <TextBlock Text="{DynamicResource ModeDownloadTitle}" FontWeight="SemiBold"
                                                           FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Text="{DynamicResource ModeDownloadDesc}"
                                                       FontSize="10" Foreground="{StaticResource TextSec}"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- UPLOAD SETTINGS -->
                        <Border x:Name="BorderUpload" Style="{StaticResource Card}"
                                Visibility="Collapsed" Opacity="0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Lbl}" Text="{DynamicResource SectionYTSettings}"/>
                                <TextBlock Text="{DynamicResource LblTitleField}" FontSize="11"
                                           Foreground="{StaticResource TextSec}" Margin="0,0,0,3"/>
                                <TextBox x:Name="TxtTitle"/>
                                <Grid Margin="0,8,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LblDescField}" FontSize="11"
                                               Foreground="{StaticResource TextSec}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Style="{StaticResource IconBtn}"
                                            ToolTip="{DynamicResource TipEditDesc}"
                                            Click="EditDescription_Click">
                                        <TextBlock Text="✏" FontSize="13"
                                                   Foreground="{StaticResource TextSec}"/>
                                    </Button>
                                </Grid>
                                <TextBox x:Name="TxtDescription" IsReadOnly="True"
                                         TextWrapping="Wrap" Height="44"
                                         VerticalScrollBarVisibility="Auto"
                                         ToolTip="{DynamicResource TipDescBox}"
                                         MouseDoubleClick="EditDescription_Click"/>
                                <TextBlock Text="{DynamicResource LblVisibility}" FontSize="11"
                                           Foreground="{StaticResource TextSec}" Margin="0,8,0,3"/>
                                <ComboBox x:Name="CmbPrivacy" SelectedIndex="0">
                                    <ComboBoxItem Content="{DynamicResource PrivacyPublic}"   Tag="public"/>
                                    <ComboBoxItem Content="{DynamicResource PrivacyUnlisted}" Tag="unlisted"/>
                                    <ComboBoxItem Content="{DynamicResource PrivacyPrivate}"  Tag="private"/>
                                </ComboBox>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ChkFingerprint" IsChecked="True"
                                              Foreground="{StaticResource TextSec}"
                                              Content="Fingerprint-Bypass" FontSize="11"
                                              VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CmbFingerprintMethod" Grid.Column="1"
                                              Margin="8,0,0,0" SelectedIndex="2"
                                              IsEnabled="{Binding IsChecked, ElementName=ChkFingerprint}">
                                        <ComboBoxItem Content="{DynamicResource FpMetadata}" Tag="metadata"/>
                                        <ComboBoxItem Content="{DynamicResource FpLight}"    Tag="light"/>
                                        <ComboBoxItem Content="{DynamicResource FpStandard}" Tag="standard"/>
                                        <ComboBoxItem Content="{DynamicResource FpStrong}"   Tag="strong"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- DOWNLOAD SETTINGS -->
                        <Border x:Name="BorderDownload" Style="{StaticResource Card}"
                                Visibility="Collapsed" Opacity="0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Lbl}" Text="{DynamicResource SectionDLSettings}"/>
                                <TextBlock Text="{DynamicResource LblSavePath}" FontSize="11"
                                           Foreground="{StaticResource TextSec}" Margin="0,0,0,3"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtOutputDir" IsReadOnly="True"/>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource OutlineBtn}"
                                            Content="{DynamicResource BtnBrowse}"
                                            Margin="8,0,0,0" Click="Browse_Click"/>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ChkFingerprintDl" IsChecked="True"
                                              Foreground="{StaticResource TextSec}"
                                              Content="Fingerprint-Bypass" FontSize="11"
                                              VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CmbFingerprintMethodDl" Grid.Column="1"
                                              Margin="8,0,0,0" SelectedIndex="2"
                                              IsEnabled="{Binding IsChecked, ElementName=ChkFingerprintDl}">
                                        <ComboBoxItem Content="{DynamicResource FpMetadata}" Tag="metadata"/>
                                        <ComboBoxItem Content="{DynamicResource FpLight}"    Tag="light"/>
                                        <ComboBoxItem Content="{DynamicResource FpStandard}" Tag="standard"/>
                                        <ComboBoxItem Content="{DynamicResource FpStrong}"   Tag="strong"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>

                <!-- START BUTTON -->
                <Button x:Name="BtnStart" Grid.Row="1" Style="{StaticResource GradBtn}"
                        Content="{DynamicResource BtnStart}" Margin="0,4,0,0"
                        Click="Start_Click"/>
            </Grid>

            <!-- ═══════════ STATUS BAR ═══════════ -->
            <Border Grid.Row="2" Background="#141416"
                    CornerRadius="0,0,8,8" Padding="12,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="6" Height="6" Margin="0,0,6,0">
                            <Ellipse.Fill>
                                <SolidColorBrush x:Name="StatusDotColor" Color="#5AAF6E"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock x:Name="TxtStatusBar" Text="{DynamicResource StatusStarting}"
                                   FontSize="10" Foreground="{StaticResource TextSec}"/>
                    </StackPanel>
                    <Button x:Name="BtnMainLog"
                            HorizontalAlignment="Right"
                            Content="▾ Log"
                            Style="{StaticResource OutlineBtn}"
                            FontSize="10" Padding="8,3"
                            IsEnabled="False"
                            Click="MainLog_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
