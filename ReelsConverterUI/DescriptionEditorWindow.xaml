<Window x:Class="ReelsConverterUI.DescriptionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beschreibung" Width="480" Height="340"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <Border x:Name="RootBorder" CornerRadius="16"
            Background="{StaticResource BgDeep}"
            BorderBrush="{StaticResource BorderSub}" BorderThickness="1"
            Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="PopScale"/>
                <TranslateTransform x:Name="PopTranslate"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#141416" CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <TextBlock Text="Beschreibung bearbeiten" FontWeight="SemiBold"
                               FontSize="12" Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <Button Style="{StaticResource IconBtn}"
                            Foreground="{StaticResource ErrorRed}"
                            Width="30" Height="30"
                            HorizontalAlignment="Right" Margin="0,0,4,0"
                            Click="Close_Click">
                        <TextBlock Text="✕" FontSize="11"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Editor -->
            <TextBox x:Name="TxtEditor"
                     Grid.Row="1"
                     Margin="12,10,12,0"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     VerticalAlignment="Stretch"
                     FontSize="12"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="12,10,12,12">
                <Button Content="Abbrechen" Style="{StaticResource OutlineBtn}"
                        Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button Content="Übernehmen" Style="{StaticResource GradBtn}"
                        Width="110" Click="Apply_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
