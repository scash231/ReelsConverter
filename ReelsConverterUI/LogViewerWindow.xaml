<Window x:Class="ReelsConverterUI.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Job Log" Width="500" Height="360"
        WindowStyle="None" AllowsTransparency="True"
        Icon="app.ico"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="8"
            Background="{StaticResource BgDeep}"
            BorderBrush="{StaticResource BorderSub}" BorderThickness="1"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="WinScale"/>
        </Border.RenderTransform>

        <Border.Triggers>
            <EventTrigger RoutedEvent="Border.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="WinScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         From="0.96" To="1" Duration="0:0:0.25">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="WinScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         From="0.96" To="1" Duration="0:0:0.25">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#141416" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="🗒 Job Log" FontWeight="SemiBold"
                                   FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                    <Button x:Name="BtnClose"
                            Style="{StaticResource IconBtn}"
                            Foreground="{StaticResource ErrorRed}"
                            Width="30" Height="30"
                            HorizontalAlignment="Right" Margin="0,0,4,0"
                            Click="Close_Click">
                        <TextBlock Text="✕" FontSize="11"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Log TextBox -->
            <TextBox x:Name="TxtLog" Grid.Row="1"
                     Margin="12,10,12,0"
                     Background="#0D0D0F"
                     BorderBrush="{StaticResource BorderSub}" BorderThickness="1"
                     Foreground="#7A9EC0"
                     FontFamily="Consolas"
                     FontSize="10"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     Padding="8,6"/>

            <!-- Footer -->
            <Grid Grid.Row="2" Margin="12,8,12,12">
                <Button Content="📋 Kopieren" Style="{StaticResource OutlineBtn}"
                        HorizontalAlignment="Left"
                        Click="Copy_Click"/>
                <Button Content="Schließen" Style="{StaticResource OutlineBtn}"
                        HorizontalAlignment="Right"
                        Click="Close_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
