<Window x:Class="ReelsConverterUI.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Video Editor" Width="820" Height="560"
        Icon="app.ico"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border x:Name="RootBorder" CornerRadius="16"
            Background="{StaticResource BgDeep}"
            BorderBrush="{StaticResource BorderSub}" BorderThickness="1"
            Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="WindowScale"/>
                <TranslateTransform x:Name="WindowTranslate"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══════════ TITLE BAR ═══════════ -->
            <Border Grid.Row="0" Background="#141416" CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="✂" FontSize="12" Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource EditorTitle}" FontWeight="SemiBold"
                                   FontSize="12" Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right"
                            Style="{StaticResource IconBtn}"
                            Foreground="{StaticResource ErrorRed}"
                            Width="30" Height="30"
                            Click="Close_Click">
                        <TextBlock Text="✕" FontSize="11"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══════════ MAIN TWO-PANEL LAYOUT ═══════════ -->
            <Grid Grid.Row="1" Margin="10,8,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- ═══════ LEFT: VIDEO PREVIEW ═══════ -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,5,0"
                        Padding="0" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Video player -->
                        <Border Grid.Row="0" Background="{StaticResource BgElevated}"
                                CornerRadius="16,16,0,0">
                            <Grid>
                                <TextBlock x:Name="TxtNoVideo"
                                           Text="{DynamicResource EditorNoVideo}"
                                           Foreground="{StaticResource TextSec}" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <MediaElement x:Name="VideoPlayer"
                                              LoadedBehavior="Manual" UnloadedBehavior="Close"
                                              ScrubbingEnabled="True" Stretch="Uniform"
                                              MediaOpened="VideoPlayer_MediaOpened"
                                              MediaEnded="VideoPlayer_MediaEnded"/>
                            </Grid>
                        </Border>

                        <!-- Playback controls -->
                        <Border Grid.Row="1" Background="{StaticResource BgCard}"
                                CornerRadius="0,0,16,16" Padding="12,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Timeline slider -->
                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="TxtCurrentTime" Grid.Column="0"
                                               Text="0:00" FontSize="10"
                                               Foreground="{StaticResource TextSec}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderTimeline" Grid.Column="1"
                                            Minimum="0" Maximum="100" Value="0"
                                            IsEnabled="False"
                                            ValueChanged="SliderTimeline_ValueChanged"
                                            PreviewMouseLeftButtonDown="SliderTimeline_DragStarted"
                                            PreviewMouseLeftButtonUp="SliderTimeline_DragCompleted"/>
                                    <TextBlock x:Name="TxtDuration" Grid.Column="2"
                                               Text="0:00" FontSize="10"
                                               Foreground="{StaticResource TextSec}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- Play/Pause + Volume -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <Button x:Name="BtnPlay" Style="{StaticResource IconBtn}"
                                            Width="34" Height="34" IsEnabled="False"
                                            Click="Play_Click">
                                        <TextBlock x:Name="TxtPlayIcon" Text="▶" FontSize="14"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </Button>
                                    <Button x:Name="BtnStop" Style="{StaticResource IconBtn}"
                                            Width="34" Height="34" IsEnabled="False"
                                            Margin="4,0,0,0" Click="Stop_Click">
                                        <TextBlock Text="⏹" FontSize="14"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </Button>
                                    <Button x:Name="BtnMuteToggle" Style="{StaticResource IconBtn}"
                                            Width="34" Height="34" IsEnabled="False"
                                            Margin="4,0,0,0" Click="MuteToggle_Click">
                                        <TextBlock x:Name="TxtMuteIcon" Text="🔊" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══════ RIGHT: TOOL PANELS ═══════ -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Margin="5,0,0,0">
                    <StackPanel>

                        <!-- FILE (compact) -->
                        <Border Style="{StaticResource Card}" Padding="10,7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtFileName" Grid.Column="0"
                                           Text="{DynamicResource EditorNoFileLoaded}"
                                           FontSize="11" Foreground="{StaticResource TextSec}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                <Button x:Name="BtnBrowseVideo" Grid.Column="1"
                                        Style="{StaticResource OutlineBtn}"
                                        FontSize="10" Padding="10,4"
                                        Content="{DynamicResource EditorBrowse}"
                                        Click="BrowseVideo_Click"/>
                            </Grid>
                        </Border>

                        <!-- TRIM -->
                        <Border Style="{StaticResource Card}" Padding="12,10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Lbl}"
                                           Text="{DynamicResource EditorTrimSection}"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource EditorTrimStart}"
                                                   FontSize="10" Foreground="{StaticResource TextSec}"
                                                   Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtTrimStart" Tag="0:00.000"
                                                 FontSize="11" IsEnabled="False"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{DynamicResource EditorTrimEnd}"
                                                   FontSize="10" Foreground="{StaticResource TextSec}"
                                                   Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtTrimEnd" Tag="0:00.000"
                                                 FontSize="11" IsEnabled="False"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button x:Name="BtnSetStart" Style="{StaticResource OutlineBtn}"
                                            FontSize="10" Padding="8,4" IsEnabled="False"
                                            Content="{DynamicResource EditorMarkStart}"
                                            Click="SetStart_Click"/>
                                    <Button x:Name="BtnSetEnd" Style="{StaticResource OutlineBtn}"
                                            FontSize="10" Padding="8,4" Margin="6,0,0,0"
                                            IsEnabled="False"
                                            Content="{DynamicResource EditorMarkEnd}"
                                            Click="SetEnd_Click"/>
                                    <Button x:Name="BtnResetTrim" Style="{StaticResource OutlineBtn}"
                                            FontSize="10" Padding="8,4" Margin="6,0,0,0"
                                            IsEnabled="False"
                                            Content="{DynamicResource EditorResetTrim}"
                                            Click="ResetTrim_Click"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkMuteAudio" IsEnabled="False"
                                          Margin="0,8,0,0"
                                          Content="{DynamicResource EditorMuteAudio}"/>
                            </StackPanel>
                        </Border>

                        <!-- SUBTITLES -->
                        <Border Style="{StaticResource Card}" Padding="12,10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Lbl}"
                                           Text="{DynamicResource EditorSubtitleSection}"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource EditorSubModel}"
                                                   FontSize="10" Foreground="{StaticResource TextSec}"
                                                   Margin="0,0,0,4"/>
                                        <ComboBox x:Name="CmbSubModel" SelectedIndex="1" FontSize="11">
                                            <ComboBoxItem Content="tiny" Tag="tiny"/>
                                            <ComboBoxItem Content="base" Tag="base"/>
                                            <ComboBoxItem Content="small" Tag="small"/>
                                            <ComboBoxItem Content="medium" Tag="medium"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{DynamicResource EditorSubLang}"
                                                   FontSize="10" Foreground="{StaticResource TextSec}"
                                                   Margin="0,0,0,4"/>
                                        <ComboBox x:Name="CmbSubLang" SelectedIndex="0" FontSize="11">
                                            <ComboBoxItem Content="Auto" Tag="auto"/>
                                            <ComboBoxItem Content="Deutsch" Tag="de"/>
                                            <ComboBoxItem Content="English" Tag="en"/>
                                            <ComboBoxItem Content="Español" Tag="es"/>
                                            <ComboBoxItem Content="Français" Tag="fr"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                                <Button x:Name="BtnGenSubs" Style="{StaticResource OutlineBtn}"
                                        Content="{DynamicResource EditorGenSubs}" IsEnabled="False"
                                        Margin="0,6,0,0" Click="GenSubs_Click"/>
                                <ProgressBar x:Name="PbSubs" Height="2" Margin="0,4,0,0"
                                             IsIndeterminate="True" Visibility="Collapsed"
                                             Foreground="{StaticResource Accent}"
                                             Background="Transparent"/>
                                <TextBlock x:Name="TxtSubStatus" FontSize="10"
                                           Foreground="{StaticResource TextSec}" Margin="0,4,0,0"
                                           Visibility="Collapsed"/>
                                <TextBox x:Name="TxtSubPreview" FontSize="10" Height="80"
                                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap" Visibility="Collapsed" Margin="0,6,0,0"/>
                                <CheckBox x:Name="ChkBurnSubs" IsEnabled="False" Margin="0,6,0,0"
                                          Content="{DynamicResource EditorBurnSubs}"/>
                            </StackPanel>
                        </Border>

                        <!-- EXPORT -->
                        <Border Style="{StaticResource Card}" Padding="12,10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Lbl}"
                                           Text="{DynamicResource EditorExportSection}"/>
                                <Button x:Name="BtnExport" Style="{StaticResource GradBtn}"
                                        Height="36" IsEnabled="False"
                                        Content="{DynamicResource EditorExport}"
                                        Click="Export_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
